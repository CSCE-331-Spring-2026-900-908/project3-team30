{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://spring-boot-production-4b42.up.railway.app/api/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "https://spring-boot-production-4b42.up.railway.app/oauth2/:path*"
    },
    {
      "source": "/login/:path*",
      "destination": "https://spring-boot-production-4b42.up.railway.app/login/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}